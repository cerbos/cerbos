{
  "$id": "https://api.cerbos.dev/cerbos/engine/v1/CrossScopePlanResourcesInput/Resource.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "google.protobuf.Value": {
      "title": "Value",
      "description": "A dynamically-typed value."
    }
  },
  "type": "object",
  "required": [
    "kind"
  ],
  "additionalProperties": false,
  "properties": {
    "attr": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/google.protobuf.Value"
      }
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^[0-9A-Z_a-z]*$"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^([0-9A-Za-z][\\-0-9A-Z_a-z]*(\\.[\\-0-9A-Z_a-z]*)*)*$"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
